# --- Speech-to-Text ---

# Groq Whisper STT (primary)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# Which Whisper model to use (default: whisper-large-v3-turbo)
# Options: whisper-large-v3, whisper-large-v3-turbo, distil-whisper-large-v3-en
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Soniox STT (fallback — kept for reference)
# Get one at: https://soniox.com
SONIOX_API_KEY=

# --- Text-to-Speech ---

# ElevenLabs TTS (primary)
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Voice ID for ElevenLabs TTS (default: George)
# Browse voices at: https://elevenlabs.io/app/voice-lab
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Model for ElevenLabs TTS (default: eleven_flash_v2_5)
# Options: eleven_flash_v2_5, eleven_multilingual_v2, eleven_turbo_v2_5
ELEVENLABS_MODEL=eleven_flash_v2_5

# --- LLM (Chat / Query engine) ---

# LLM API key — OpenAI, or any OpenAI-compatible provider
# Get one at: https://platform.openai.com/api-keys  (OpenAI)
#             https://console.groq.com/keys         (Groq)
#             https://openrouter.ai/keys            (OpenRouter)
#             https://ai.google.dev/                (Gemini via OpenAI compat)
OPENAI_API_KEY=

# LLM API base URL (default: OpenAI)
# OpenAI:     https://api.openai.com/v1
# Groq:       https://api.groq.com/openai/v1
# OpenRouter: https://openrouter.ai/api/v1
# Together:   https://api.together.xyz/v1
# Gemini:     https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM model to use (optional, default: gpt-4o-mini)
# OpenAI:  gpt-4o-mini, gpt-4o, o3-mini
# Groq:    llama-3.3-70b-versatile, deepseek-r1-distill-llama-70b
# OpenRouter: google/gemini-2.0-flash-001, anthropic/claude-3.5-sonnet
# Together:  mistralai/Mixtral-8x22B-Instruct-v0.1
OPENAI_MODEL=gpt-4o-mini

# Enable OpenAI’s json_object response format (default: true)
# Set to false for providers that don’t support it (Groq, Gemini, etc.)
# The system prompt will still instruct the LLM to output JSON.
OPENAI_JSON_MODE=false

# --- Database ---

# MongoDB connection URI (optional — features degrade gracefully when unset)
# Default: mongodb://localhost:27017
# To disable: leave MONGO_URI empty
MONGO_URI=mongodb://localhost:27017
